# =============================================================================
# RustyTalon Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Only DATABASE_URL (or LIBSQL_PATH) and one LLM provider key are required.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Backend: "postgres" (default) or "libsql"
DATABASE_BACKEND=postgres

# PostgreSQL (when DATABASE_BACKEND=postgres)
DATABASE_URL=postgres://localhost/rustytalon
DATABASE_POOL_SIZE=10

# libSQL / Turso (when DATABASE_BACKEND=libsql)
# LIBSQL_PATH=~/.rustytalon/rustytalon.db   # local embedded (default)
# LIBSQL_URL=libsql://your-db.turso.io      # Turso cloud (optional)
# LIBSQL_AUTH_TOKEN=                         # required with LIBSQL_URL

# -----------------------------------------------------------------------------
# LLM Provider (pick one)
# -----------------------------------------------------------------------------
# Options: anthropic (default), openai, ollama, openai_compatible
LLM_BACKEND=anthropic

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_BASE_URL=https://api.anthropic.com      # Custom base URL (optional, for proxies/gateways)
# ANTHROPIC_EXTRA_HEADERS="key=value,key2=value2"  # Extra HTTP headers (optional, comma-separated)
#   NOTE: Quote values containing '=' signs (dotenvy requires it)

# OpenAI
# LLM_BACKEND=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Ollama (local)
# LLM_BACKEND=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# OpenAI-compatible API (also works with Cloudflare AI Gateway, LiteLLM, etc.)
# LLM_BACKEND=openai_compatible
# LLM_BASE_URL=https://api.example.com/v1
# LLM_API_KEY=...
# LLM_MODEL=model-name
# LLM_EXTRA_HEADERS="key=value,key2=value2"  # extra HTTP headers (comma-separated, quote if values contain '=')

# -----------------------------------------------------------------------------
# Smart Routing
# -----------------------------------------------------------------------------
ROUTING_ENABLED=true
ROUTING_STRATEGY=balanced                    # balanced, cost, quality, local_first
# ROUTING_MAX_COST=0.05                     # Max USD per request (optional)
ROUTING_MIN_QUALITY=0.5                      # Min quality score 0.0-1.0
ROUTING_ENABLE_FALLBACK=true
ROUTING_MAX_RETRIES=3
# ROUTING_PREFERRED_PROVIDERS=anthropic,openai
# ROUTING_EXCLUDED_PROVIDERS=

# -----------------------------------------------------------------------------
# Embeddings (for semantic memory search)
# -----------------------------------------------------------------------------
# Requires an OpenAI API key (reuses OPENAI_API_KEY if set)
# OPENAI_API_KEY=sk-...
EMBEDDING_ENABLED=false
EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Web Gateway
# -----------------------------------------------------------------------------
GATEWAY_ENABLED=true
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=3001
GATEWAY_AUTH_TOKEN=changeme                  # CHANGE THIS for any non-local deployment
GATEWAY_USER_ID=default

# -----------------------------------------------------------------------------
# Agent Settings
# -----------------------------------------------------------------------------
AGENT_NAME=rustytalon
AGENT_MAX_PARALLEL_JOBS=5
AGENT_JOB_TIMEOUT_SECS=3600
AGENT_STUCK_THRESHOLD_SECS=300
AGENT_USE_PLANNING=true

# -----------------------------------------------------------------------------
# Channels
# -----------------------------------------------------------------------------
# HTTP Webhook (optional)
# HTTP_HOST=0.0.0.0
# HTTP_PORT=8080
# HTTP_WEBHOOK_SECRET=your-webhook-secret

# Telegram Bot (optional, WASM channel)
# TELEGRAM_BOT_TOKEN=...

# Slack Bot (optional, WASM channel)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_SIGNING_SECRET=...

# -----------------------------------------------------------------------------
# Docker Sandbox
# -----------------------------------------------------------------------------
SANDBOX_ENABLED=false
SANDBOX_IMAGE=rustytalon-worker:latest
SANDBOX_MEMORY_LIMIT_MB=512
SANDBOX_TIMEOUT_SECS=1800

# Claude Code mode (runs inside sandbox containers)
CLAUDE_CODE_ENABLED=false
CLAUDE_CODE_MODEL=claude-sonnet-4-20250514
CLAUDE_CODE_MAX_TURNS=50
# CLAUDE_CODE_CONFIG_DIR=/home/worker/.claude

# -----------------------------------------------------------------------------
# Routines (scheduled/reactive execution)
# -----------------------------------------------------------------------------
ROUTINES_ENABLED=true
ROUTINES_CRON_INTERVAL=60                    # Tick interval in seconds
ROUTINES_MAX_CONCURRENT=3

# -----------------------------------------------------------------------------
# Heartbeat (proactive periodic execution)
# -----------------------------------------------------------------------------
HEARTBEAT_ENABLED=false
HEARTBEAT_INTERVAL_SECS=1800                 # 30 minutes
HEARTBEAT_NOTIFY_CHANNEL=cli
HEARTBEAT_NOTIFY_USER=default

# -----------------------------------------------------------------------------
# Self-repair
# -----------------------------------------------------------------------------
SELF_REPAIR_CHECK_INTERVAL_SECS=60
SELF_REPAIR_MAX_ATTEMPTS=3

# -----------------------------------------------------------------------------
# Safety
# -----------------------------------------------------------------------------
SAFETY_MAX_OUTPUT_LENGTH=100000
SAFETY_INJECTION_CHECK_ENABLED=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
RUST_LOG=rustytalon=info
