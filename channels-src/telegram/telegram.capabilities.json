{
  "type": "channel",
  "name": "telegram",
  "description": "Telegram Bot API channel for receiving and responding to Telegram messages",
  "capabilities": {
    "http": {
      "allowlist": [{ "host": "api.telegram.org", "path_prefix": "/bot" }],
      "credentials": {
        "telegram_bot": {
          "secret_name": "telegram_bot_token",
          "location": { "type": "url_path", "placeholder": "{TELEGRAM_BOT_TOKEN}" },
          "host_patterns": ["api.telegram.org"]
        }
      },
      "rate_limit": { "requests_per_minute": 30, "requests_per_hour": 1000 }
    },
    "secrets": { "allowed_names": ["telegram_*"] },
    "channel": {
      "allowed_paths": ["/webhook/telegram"],
      "allow_polling": true,
      "min_poll_interval_ms": 30000,
      "workspace_prefix": "channels/telegram/",
      "emit_rate_limit": { "messages_per_minute": 100, "messages_per_hour": 5000 }
    }
  },
  "config": {
    "bot_username": null,
    "owner_id": null,
    "respond_to_all_group_messages": false,
    "polling_enabled": false,
    "poll_interval_ms": 30000,
    "dm_policy": "pairing",
    "allow_from": []
  },
  "config_schema": {
    "type": "object",
    "properties": {
      "bot_username": {
        "type": "string",
        "nullable": true,
        "description": "Your bot's username (e.g. @mybot). Used for @mentions in groups."
      },
      "owner_id": {
        "type": "string",
        "nullable": true,
        "description": "Your Telegram user ID. Only messages from this user will be processed."
      },
      "respond_to_all_group_messages": {
        "type": "boolean",
        "default": false,
        "description": "If true, respond to all group messages (not just @mentions)."
      },
      "polling_enabled": {
        "type": "boolean",
        "default": false,
        "description": "Enable long-polling for updates (use when webhooks are not available)."
      },
      "poll_interval_ms": {
        "type": "integer",
        "default": 30000,
        "minimum": 30000,
        "description": "Polling interval in milliseconds (minimum 30000)."
      },
      "dm_policy": {
        "type": "string",
        "enum": ["pairing", "owner_only", "anyone"],
        "default": "pairing",
        "description": "Who can send DMs to the bot."
      },
      "allow_from": {
        "type": "array",
        "items": { "type": "string" },
        "default": [],
        "description": "Additional Telegram user IDs allowed to send messages (comma-separated)."
      }
    }
  }
}
