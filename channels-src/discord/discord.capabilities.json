{
  "type": "channel",
  "name": "discord",
  "description": "Discord DM channel for RustyTalon — polls DM channels for new messages and responds in-DM",
  "setup": {
    "required_secrets": [
      {
        "name": "discord_bot_token",
        "prompt": "Enter your Discord bot token (from discord.com/developers → Your App → Bot → Token)",
        "validation": "^[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+$"
      }
    ],
    "validation_endpoint": "https://discord.com/api/v10/users/@me"
  },
  "capabilities": {
    "http": {
      "allowlist": [
        { "host": "discord.com", "path_prefix": "/api/" }
      ],
      "credentials": {
        "discord_bot": {
          "secret_name": "discord_bot_token",
          "location": { "type": "header", "name": "Authorization", "prefix": "Bot " },
          "host_patterns": ["discord.com"]
        }
      },
      "rate_limit": {
        "requests_per_minute": 30,
        "requests_per_hour": 500
      }
    },
    "secrets": {
      "allowed_names": ["discord_*"]
    },
    "channel": {
      "allowed_paths": [],
      "allow_polling": true,
      "min_poll_interval_ms": 30000,
      "workspace_prefix": "channels/discord/",
      "emit_rate_limit": {
        "messages_per_minute": 100,
        "messages_per_hour": 5000
      },
      "connection": {
        "type": "websocket",
        "url": "wss://gateway.discord.gg/?v=10&encoding=json",
        "keepalive": {
          "type": "json_opcode",
          "interval_field": "d.heartbeat_interval",
          "send": { "op": 1, "d": null },
          "expect": { "op": 11 },
          "fallback_interval_ms": 41250
        },
        "handshake": {
          "wait_for_op": 10,
          "send": {
            "op": 2,
            "d": {
              "token": "{DISCORD_BOT_TOKEN}",
              "intents": 37377,
              "properties": {
                "os": "linux",
                "browser": "rustytalon",
                "device": "rustytalon"
              }
            }
          },
          "expect_op": 0
        },
        "reconnect": {
          "max_retries": 5,
          "backoff_ms": 1000,
          "resumable": true
        },
        "events": {
          "deliver_to_wasm": ["MESSAGE_CREATE"],
          "drop": ["PRESENCE_UPDATE", "TYPING_START", "GUILD_MEMBER_LIST_UPDATE"],
          "type_field": "t"
        },
        "max_event_size": 65536,
        "event_queue_size": 100,
        "additional_allowlist": [
          { "host": "gateway.discord.gg" }
        ]
      }
    }
  },
  "config": {
    "owner_id": null,
    "dm_policy": "pairing",
    "allow_from": []
  },
  "config_schema": {
    "type": "object",
    "properties": {
      "owner_id": {
        "type": "string",
        "nullable": true,
        "description": "Your Discord user ID. Only messages from this user will be processed. Leave blank to allow anyone."
      },
      "dm_policy": {
        "type": "string",
        "enum": ["pairing", "owner_only", "anyone"],
        "default": "pairing",
        "description": "Who can send DMs to the bot. 'pairing' requires a /pair command first."
      },
      "allow_from": {
        "type": "array",
        "items": { "type": "string" },
        "default": [],
        "description": "Additional Discord user IDs allowed to send messages (comma-separated)."
      }
    }
  }
}
